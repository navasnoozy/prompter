{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal frontend capability for Prompter's local main webview",
  "webviews": [
    "main"
  ],
  "platforms": [
    "macOS"
  ],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "allow-get-provider-navigation-state",
    "allow-control-provider-navigation",
    "allow-show-provider-webview",
    "allow-resize-provider-webview",
    "allow-set-provider-visibility",
    "allow-place-prompt",
    "allow-get-quick-capture-status",
    "allow-request-quick-capture-permission",
    "allow-open-quick-capture-settings",
    "allow-retry-quick-capture-registration",
    "allow-read-clipboard-text",
    "allow-list-quick-capture-outcomes",
    "allow-acknowledge-quick-capture-outcomes",
    "allow-get-app-lifecycle-status",
    "allow-set-launch-at-login",
    "allow-load-settings",
    "allow-save-settings"
  ]
}
